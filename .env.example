# Copy this file to `.env` and fill in your Supabase project values.
# VITE_* vars are inlined into the client bundle. The anon key is safe to expose
# because Row Level Security protects all data.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Only used by `npm run db:migrate` (server-side). Connection string from
# Supabase → Project Settings → Database → Connection string (URI). Holds the DB
# password: do NOT prefix with VITE_ and never commit it.
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
